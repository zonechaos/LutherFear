-- Utility functions
function DeityFluent:Create(className, properties, children)
    local obj = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        obj[prop] = value
    end
    for _, child in ipairs(children or {}) do
        child.Parent = obj
    end
    return obj
end

function DeityFluent:Connect(signal, callback)
    local conn
    conn = signal:Connect(function(...)
        local success, err = pcall(callback, ...)
        if not success then
            warn("[DeityFluent] Error in connection:", err)
        end
    end)
    table.insert(self.Connections, conn)
    return conn
end

function DeityFluent:Tween(object, properties, duration, style, direction)
    if not self.Settings.AnimationSpeed then return end
    local tweenInfo = TweenInfo.new(duration or self.Settings.AnimationSpeed, 
        style or Enum.EasingStyle.Quad, 
        direction or Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

function DeityFluent:GetIcon(iconName)
    -- You can add your icon assets here
    local icons = {
        home = "rbxassetid://6031092379",
        settings = "rbxassetid://6031087587",
        user = "rbxassetid://6031091788",
        cog = "rbxassetid://6031087587",
        "rbxassetid://6031092379" -- default
    }
    return icons[iconName] or icons[#icons]
end

