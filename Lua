            self:Connect(toggleBtn.Activated, function()
                updateToggle(not toggleValue)
            end)
            
            if options.flag then
                DeityFluent.Flags[options.flag] = toggleValue
            end
            
            return {
                SetValue = updateToggle,
                GetValue = function() return toggleValue end
