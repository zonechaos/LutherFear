                self:Create("UIStroke", {
                    Color = DeityFluent.CurrentTheme.Border,
                    Transparency = 0.5
                })
            })
            
            local title = self:Create("TextLabel", {
                Parent = sliderFrame,
                Text = options.title or "Slider",
                TextColor3 = DeityFluent.CurrentTheme.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                Position = UDim2.new(0, 12, 0, 12),
                Size = UDim2.new(1, -24, 0, 20),
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local min = options.min or 0
            local max = options.max or 100
            local value = options.default or min
            local decimal = options.decimal or 0
            
            local valueLabel = self:Create("TextLabel", {
                Parent = sliderFrame,
                Text = tostring(value),
                TextColor3 = DeityFluent.CurrentTheme.Accent,
                TextSize = 14,
                Font = Enum.Font.GothamBold,
                Position = UDim2.new(1, -12, 0, 12),
                AnchorPoint = Vector2.new(1, 0),
                Size = UDim2.new(0, 60, 0, 20),
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local sliderBar = self:Create("Frame", {
                Parent = sliderFrame,
                Size = UDim2.new(1, -24, 0, 4),
                Position = UDim2.new(0, 12, 0, 44),
                BackgroundColor3 = Color3.fromRGB(60, 60, 70),
                BorderSizePixel = 0
            }, {
                self:Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local sliderFill = self:Create("Frame", {
                Parent = sliderBar,
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = DeityFluent.CurrentTheme.Accent,
                BorderSizePixel = 0
            }, {
                self:Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local sliderKnob = self:Create("Frame", {
                Parent = sliderBar,
                Size = UDim2.new(0, 12, 0, 12),
                Position = UDim2.new((value - min) / (max - min), -6, 0.5, -6),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = DeityFluent.CurrentTheme.Accent,
                BorderSizePixel = 0
            }, {
                self:Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local function updateValue(newValue)
                value = math.clamp(newValue, min, max)
                if decimal > 0 then
                    value = math.round(value / decimal) * decimal
                end
                local percent = (value - min) / (max - min)
                
                valueLabel.Text = tostring(value)
                self:Tween(sliderFill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.1)
                self:Tween(sliderKnob, {Position = UDim2.new(percent, -6, 0.5, -6)}, 0.1)
                
                if options.callback then
                    options.callback(value)
                end
                if options.flag then
                    DeityFluent.Flags[options.flag] = value
                end
            end
            
            local dragging = false
            self:Connect(sliderKnob.InputBegan, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                end
            end)
            
            self:Connect(UserInputService.InputEnded, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            self:Connect(UserInputService.InputChanged, function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local percent = (input.Position.X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X
                    local newValue = min + (max - min) * math.clamp(percent, 0, 1)
                    updateValue(newValue)
                end
            end)
            
            if options.flag then
                DeityFluent.Flags[options.flag] = value
            end
            
            return {
                SetValue = updateValue,
                GetValue = function() return value end
            }
        end
        
        function tab:AddDropdown(options)
            options = options or {}
            
            local dropdownFrame = self:Create("Frame", {
                Parent = tab.Container,
                Size = UDim2.new(1, 0, 0, 48),
                BackgroundColor3 = DeityFluent.CurrentTheme.Surface,
                BackgroundTransparency = 0.9,
                BorderSizePixel = 0
            }, {
                self:Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
                self:Create("UIStroke", {
                    Color = DeityFluent.CurrentTheme.Border,
                    Transparency = 0.5
                })
            })
            
            local title = self:Create("TextLabel", {
                Parent = dropdownFrame,
                Text = options.title or "Dropdown",
                TextColor3 = DeityFluent.CurrentTheme.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                Position = UDim2.new(0, 12, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Size = UDim2.new(0.5, 0, 0, 20),
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local dropdownBtn = self:Create("TextButton", {
                Parent = dropdownFrame,
                Text = options.values and options.values[1] or "Select",
                TextColor3 = DeityFluent.CurrentTheme.Text,
                TextSize = 13,
                Font = Enum.Font.Gotham,
                Size = UDim2.new(0, 120, 0, 32),
                Position = UDim2.new(1, -12, 0.5, 0),
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundColor3 = DeityFluent.CurrentTheme.Surface,
                BackgroundTransparency = 0.5
            }, {
                self:Create("UICorner", {CornerRadius = UDim.new(0, 6)}),
                self:Create("UIStroke", {
                    Color = DeityFluent.CurrentTheme.Border,
                    Transparency = 0.5
                })
            })
            
            local dropdownMenu = self:Create("Frame", {
                Parent = screenGui,
                Size = UDim2.new(0, 120, 0, 0),
                BackgroundColor3 = DeityFluent.CurrentTheme.Surface,
                Visible = false,
                ZIndex = 10
            }, {
                self:Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
                self:Create("UIStroke", {
                    Color = DeityFluent.CurrentTheme.Border,
                    Transparency = 0.5
                }),
                self:Create("UIListLayout", {
                    Padding = UDim.new(0, 2)
                })
            })
            
            local selectedValue = options.default or (options.values and options.values[1])
            local values = options.values or {}
            
            for _, val in ipairs(values) do
                local option = self:Create("TextButton", {
                    Parent = dropdownMenu,
                    Text = val,
                    TextColor3 = DeityFluent.CurrentTheme.Text,
                    TextSize = 13,
                    Font = Enum.Font.Gotham,
                    Size = UDim2.new(1, 0, 0, 32),
                    BackgroundColor3 = DeityFluent.CurrentTheme.Surface,
                    BackgroundTransparency = 0.9,
                    AutoButtonColor = false
                }, {
                    self:Create("UICorner", {CornerRadius = UDim.new(0, 6)})
                })
                
                self:Connect(option.Activated, function()
                    selectedValue = val
                    dropdownBtn.Text = val
                    dropdownMenu.Visible = false
                    
                    if options.callback then
                        options.callback(val)
                    end
                    if options.flag then
                        DeityFluent.Flags[options.flag] = val
                    end
                end)
                
                dropdownMenu.Size = UDim2.new(0, 120, 0, dropdownMenu.UIListLayout.AbsoluteContentSize.Y + 4)
            end
            
            local function updatePosition()
                local pos = dropdownBtn.AbsolutePosition
                dropdownMenu.Position = UDim2.new(0, pos.X + dropdownBtn.AbsoluteSize.X - 120, 0, pos.Y + dropdownBtn.AbsoluteSize.Y + 2)
            end
            
            self:Connect(dropdownBtn.Activated, function()
                dropdownMenu.Visible = not dropdownMenu.Visible
                if dropdownMenu.Visible then
                    updatePosition()
                end
            end)
            
            self:Connect(UserInputService.InputBegan, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if dropdownMenu.Visible and not dropdownBtn:IsHovering() and not dropdownMenu:IsHovering() then
                        dropdownMenu.Visible = false
                    end
                end
            end)
            
            if options.flag then
                DeityFluent.Flags[options.flag] = selectedValue
            end
            
            return {
                SetValue = function(val)
                    selectedValue = val
                    dropdownBtn.Text = val
                    if options.callback then
                        options.callback(val)
                    end
                end,
                GetValue = function() return selectedValue end
            }
        end
        
        return tab
    end
    
    table.insert(DeityFluent.Windows, window)
    return window
end

